# Copy this file to .herald-release.env for local release-style OAuth builds.
# .herald-release.env is ignored by git and must never be committed.
# Run `make build-release-local` to require these values before building all local binaries.
# Plain `make build` uses .herald-dev.env instead.

HERALD_GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com
HERALD_GOOGLE_CLIENT_SECRET=your-client-secret
