# Copy this file to .herald-release.env for local OAuth-enabled release builds.
# .herald-release.env is ignored by git and must never be committed.
# Run `make build-release-local` to embed these values into local binaries.
# Plain `make build` intentionally does not embed them.

HERALD_GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com
HERALD_GOOGLE_CLIENT_SECRET=your-client-secret
