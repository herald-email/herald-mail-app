Output assets/demo/image-preview.gif

Set Theme "Builtin Solarized Dark"
Set FontSize 13
Set Width 1400
Set Height 700
Set Padding 8

Type "./bin/herald --demo -image-protocol=kitty"
Enter
Sleep 3s

# Open the Creative Commons sampler without relying on row position.
Type "/"
Sleep 0.2s
Type "Creative Commons image sampler"
Sleep 0.2s
Enter
Sleep 0.8s

# Open preview, expand to full-screen, and scroll to the first inline image placement.
Enter
Sleep 1s
Type "z"
Sleep 1.2s
Down 14
Sleep 2s
