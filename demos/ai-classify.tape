Output static/ai-classify.gif

Set Theme "Catppuccin Mocha"
Set FontSize 13
Set Width 1400
Set Height 700
Set Padding 8

Type "./bin/herald --demo"
Enter
Sleep 3s

# Run AI classification
Type "a"
Sleep 4s

# Navigate to see tagged results
Down
Sleep 0.3s
Down
Sleep 0.3s
Down
Sleep 0.3s

Sleep 1s

Type "q"
