Output assets/demo/ai-classify.gif

Set Theme "Builtin Solarized Dark"
Set FontSize 13
Set Width 1400
Set Height 700
Set Padding 8

Type "./bin/herald --demo"
Enter
Sleep 3s

# Run AI classification
Type "a"
Sleep 2s

# Navigate to see tagged results
Down
Sleep 0.3s
Down
Sleep 0.3s
Down
Sleep 0.3s

Type "2"
Sleep 1s

Type "q"
