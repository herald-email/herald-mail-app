Output assets/demo/semantic-search.gif

Set Theme "Catppuccin Mocha"
Set FontSize 13
Set Width 1400
Set Height 700
Set Padding 8

Type "./bin/herald --demo"
Enter
Sleep 3s

# Open semantic search
Type "?"
Sleep 0.5s

# Type a search query
Type "infrastructure budget risk"
Sleep 0.5s
Enter
Sleep 1.2s

# Navigate results
Down
Sleep 0.4s

# Open result
Enter
Sleep 1.2s

Escape
Sleep 0.5s

Type "q"
