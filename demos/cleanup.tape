Output assets/demo/cleanup.gif

Set Theme "Builtin Solarized Dark"
Set FontSize 13
Set Width 1400
Set Height 700
Set Padding 8

Type "./bin/herald --demo"
Enter
Sleep 3s

# Switch to Cleanup tab
Type "3"
Sleep 1s

# Navigate senders
Down
Sleep 0.4s
Down
Sleep 0.4s

# Open sender details, then preview a message
Enter
Sleep 0.6s

Tab
Sleep 0.3s
Down
Sleep 0.3s

Enter
Sleep 1s

Down
Sleep 0.4s

Escape
Sleep 0.5s

# Toggle domain mode
Type "d"
Sleep 1s

Type "d"
Sleep 0.5s

Type "q"
