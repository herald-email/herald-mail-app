Output assets/demo/cleanup.gif

Set Theme "Builtin Solarized Dark"
Set FontSize 13
Set Width 1400
Set Height 700
Set Padding 8

Type "./bin/herald --demo"
Enter
Sleep 3s

# Switch Timeline into sender grouping
Type "G"
Sleep 1s

# Navigate sender groups
Down
Sleep 0.4s
Down
Sleep 0.4s

# Open a grouped preview
Enter
Sleep 1s

Down
Sleep 0.4s

Escape
Sleep 0.5s

# Toggle domain grouping
Type "G"
Sleep 1s

Type "G"
Sleep 0.5s

Type "q"
