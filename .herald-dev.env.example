# Copy this file to .herald-dev.env for local development OAuth-enabled builds.
# .herald-dev.env is ignored by git and must never be committed.
# Plain `make build` embeds these values when both are present.
# If either value is absent, make build still succeeds without OAuth defaults
# and Herald shows the normal Google OAuth credentials-not-configured message.

HERALD_GOOGLE_CLIENT_ID=your-dev-client-id.apps.googleusercontent.com
HERALD_GOOGLE_CLIENT_SECRET=your-dev-client-secret
